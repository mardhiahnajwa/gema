# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Gema
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-me-to-a-secure-random-string

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=gema
POSTGRES_PASSWORD=gema_secret
POSTGRES_DB=gema
DATABASE_URL=postgresql+asyncpg://gema:gema_secret@db:5432/gema
SYNC_DATABASE_URL=postgresql://gema:gema_secret@db:5432/gema

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MongoDB (vector store for RAG) ───────────────────────────────────────────
MONGODB_URL=mongodb://mongo:27017/?directConnection=true
MONGODB_DB=gema
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# ── Nginx ─────────────────────────────────────────────────────────────────────
NGINX_PORT=80

# ══════════════════════════════════════════════════════════════════════════════
#  AI Provider API Keys — add the ones you have
# ══════════════════════════════════════════════════════════════════════════════

# OpenAI  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic  →  https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google AI Studio  →  https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Mistral  →  https://console.mistral.ai/
MISTRAL_API_KEY=

# Cohere  →  https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Groq (fast inference)  →  https://console.groq.com/keys
GROQ_API_KEY=

# Together AI  →  https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# HuggingFace  →  https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Azure OpenAI (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
